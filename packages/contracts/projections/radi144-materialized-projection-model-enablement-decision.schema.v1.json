{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radiquant.local/contracts/projections/radi144-materialized-projection-model-enablement-decision.schema.v1.json",
  "title": "radiquant-v5 Radi144 Materialized Projection Model Enablement Decision Gate v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "decision",
    "status",
    "model_enablement_decision_recorded",
    "orm_model_enabled",
    "alembic_migration_enabled",
    "projection_storage_tables_enabled",
    "projection_write_service_enabled",
    "worker_projection_materialization_enabled",
    "required_future_gate",
    "enablement_preconditions",
    "required_invariants"
  ],
  "properties": {
    "schema_id": { "type": "string", "const": "radi144_materialized_projection_model_enablement_decision_v1" },
    "decision": { "type": "string", "const": "defer_model_enablement_until_explicit_implementation_gate" },
    "status": { "type": "string", "const": "model_enablement_decision_recorded_model_disabled" },
    "model_enablement_decision_recorded": { "type": "boolean", "const": true },
    "orm_model_enabled": { "type": "boolean", "const": false },
    "alembic_migration_enabled": { "type": "boolean", "const": false },
    "projection_storage_tables_enabled": { "type": "boolean", "const": false },
    "projection_write_service_enabled": { "type": "boolean", "const": false },
    "worker_projection_materialization_enabled": { "type": "boolean", "const": false },
    "required_future_gate": { "type": "string", "const": "radi144_materialized_projection_orm_implementation_gate_decision" },
    "enablement_preconditions": { "type": "array", "items": { "type": "string" }, "minItems": 5, "uniqueItems": true },
    "required_invariants": { "type": "array", "items": { "type": "string" }, "minItems": 7, "uniqueItems": true }
  }
}
