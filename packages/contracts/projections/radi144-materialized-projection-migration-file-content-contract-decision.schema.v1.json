{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radiquant.local/contracts/projections/radi144-materialized-projection-migration-file-content-contract-decision.schema.v1.json",
  "title": "radiquant-v5 Radi144 Materialized Projection Migration File Content Contract Decision Gate v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "decision",
    "status",
    "migration_file_content_contract_decision_recorded",
    "planned_revision_file",
    "planned_revision",
    "planned_down_revision",
    "planned_table",
    "content_contract",
    "migration_file_enabled",
    "migration_file_creation_allowed",
    "alembic_revision_file_enabled",
    "alembic_migration_enabled",
    "projection_storage_tables_enabled",
    "orm_model_enabled",
    "projection_write_service_enabled",
    "worker_projection_materialization_enabled",
    "required_future_gate",
    "required_invariants"
  ],
  "properties": {
    "schema_id": { "type": "string", "const": "radi144_materialized_projection_migration_file_content_contract_decision_v1" },
    "decision": { "type": "string", "const": "record_migration_file_content_contract_without_file_creation" },
    "status": { "type": "string", "const": "migration_file_content_contract_recorded_no_file" },
    "migration_file_content_contract_decision_recorded": { "type": "boolean", "const": true },
    "planned_revision_file": { "type": "string", "const": "apps/api/alembic/versions/0008_module_projections.py" },
    "planned_revision": { "type": "string", "const": "0008_module_projections" },
    "planned_down_revision": { "type": "string", "const": "0007_engine_result_storage" },
    "planned_table": { "type": "string", "const": "module_projections" },
    "content_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_sections", "required_revision_identifiers", "required_imports", "required_upgrade_steps", "required_downgrade_steps", "forbidden_content"],
      "properties": {
        "required_sections": { "type": "array", "items": { "type": "string" }, "minItems": 4, "uniqueItems": true },
        "required_revision_identifiers": { "type": "object", "additionalProperties": { "type": "string" }, "minProperties": 2 },
        "required_imports": { "type": "array", "items": { "type": "string" }, "minItems": 2, "uniqueItems": true },
        "required_upgrade_steps": { "type": "array", "items": { "type": "string" }, "minItems": 5, "uniqueItems": true },
        "required_downgrade_steps": { "type": "array", "items": { "type": "string" }, "minItems": 3, "uniqueItems": true },
        "forbidden_content": { "type": "array", "items": { "type": "string" }, "minItems": 5, "uniqueItems": true }
      }
    },
    "migration_file_enabled": { "type": "boolean", "const": false },
    "migration_file_creation_allowed": { "type": "boolean", "const": false },
    "alembic_revision_file_enabled": { "type": "boolean", "const": false },
    "alembic_migration_enabled": { "type": "boolean", "const": false },
    "projection_storage_tables_enabled": { "type": "boolean", "const": false },
    "orm_model_enabled": { "type": "boolean", "const": false },
    "projection_write_service_enabled": { "type": "boolean", "const": false },
    "worker_projection_materialization_enabled": { "type": "boolean", "const": false },
    "required_future_gate": { "type": "string", "const": "radi144_materialized_projection_migration_file_authoring_gate_decision" },
    "required_invariants": { "type": "array", "items": { "type": "string" }, "minItems": 8, "uniqueItems": true }
  }
}
