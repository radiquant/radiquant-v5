{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radiquant.local/contracts/projections/radi144-materialized-projection-table-ddl-implementation-decision.schema.v1.json",
  "title": "radiquant-v5 Radi144 Materialized Projection Table DDL Implementation Decision Gate v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "decision",
    "status",
    "ddl_implementation_decision_recorded",
    "planned_table",
    "ddl_implementation_enabled",
    "alembic_migration_enabled",
    "projection_storage_tables_enabled",
    "orm_model_enabled",
    "projection_write_service_enabled",
    "worker_projection_materialization_enabled",
    "required_future_gate",
    "ddl_implementation_preconditions",
    "required_invariants"
  ],
  "properties": {
    "schema_id": { "type": "string", "const": "radi144_materialized_projection_table_ddl_implementation_decision_v1" },
    "decision": { "type": "string", "const": "defer_ddl_implementation_until_alembic_revision_gate" },
    "status": { "type": "string", "const": "ddl_implementation_decision_recorded_no_ddl" },
    "ddl_implementation_decision_recorded": { "type": "boolean", "const": true },
    "planned_table": { "type": "string", "const": "module_projections" },
    "ddl_implementation_enabled": { "type": "boolean", "const": false },
    "alembic_migration_enabled": { "type": "boolean", "const": false },
    "projection_storage_tables_enabled": { "type": "boolean", "const": false },
    "orm_model_enabled": { "type": "boolean", "const": false },
    "projection_write_service_enabled": { "type": "boolean", "const": false },
    "worker_projection_materialization_enabled": { "type": "boolean", "const": false },
    "required_future_gate": { "type": "string", "const": "radi144_materialized_projection_alembic_revision_gate_decision" },
    "ddl_implementation_preconditions": { "type": "array", "items": { "type": "string" }, "minItems": 8, "uniqueItems": true },
    "required_invariants": { "type": "array", "items": { "type": "string" }, "minItems": 8, "uniqueItems": true }
  }
}
