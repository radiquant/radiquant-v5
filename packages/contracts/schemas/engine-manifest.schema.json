{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radiquant.local/contracts/engine-manifest.schema.json",
  "title": "radiquant-v5 Engine Manifest v1",
  "type": "object",
  "required": [
    "version",
    "status",
    "module_id",
    "phase",
    "runtime_scope",
    "workflow_bindings",
    "required_pre_gates",
    "required_post_gates",
    "inputs",
    "outputs",
    "result_contract",
    "substeps",
    "events",
    "provenance",
    "safety"
  ],
  "properties": {
    "version": { "type": "string" },
    "status": { "type": "string" },
    "module_id": { "type": "string" },
    "phase": { "type": "string" },
    "runtime_scope": { "type": "object" },
    "workflow_bindings": { "type": "array", "minItems": 1 },
    "required_pre_gates": { "type": "array", "minItems": 1 },
    "required_post_gates": { "type": "array", "minItems": 1 },
    "inputs": { "type": "array", "minItems": 1 },
    "outputs": { "type": "array", "minItems": 1 },
    "result_contract": { "type": "object" },
    "substeps": { "type": "array", "minItems": 1 },
    "events": { "type": "object" },
    "provenance": { "type": "object" },
    "safety": { "type": "object" }
  }
}
