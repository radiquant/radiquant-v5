{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radiquant.local/contracts/event-envelope.schema.v1.json",
  "title": "radiquant-v5 Event Envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_id", "event_type", "occurred_at", "tenant_id", "correlation_id", "payload"],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "minLength": 1, "maxLength": 120 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "tenant_id": { "type": "string", "format": "uuid" },
    "correlation_id": { "type": "string", "minLength": 1, "maxLength": 120 },
    "session_id": { "type": ["string", "null"], "format": "uuid" },
    "workflow_run_id": { "type": ["string", "null"], "format": "uuid" },
    "workflow_step_run_id": { "type": ["string", "null"], "format": "uuid" },
    "resource_type": { "type": ["string", "null"], "maxLength": 120 },
    "resource_id": { "type": ["string", "null"], "maxLength": 120 },
    "payload": { "type": "object" }
  }
}
